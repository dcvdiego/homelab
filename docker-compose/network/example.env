# Cloudflare Tunnel token (different per endpoint — set in Portainer UI)
TUNNEL_TOKEN=

# HOST_IP: LAN IP of the host this stack is deployed on.
# Binds Technitium DNS port 53 to the LAN interface only.
# docker-tower (ep2): 192.168.1.248
# docker-prod  (ep3): 192.168.1.224
HOST_IP=192.168.1.x

# Technitium web UI admin password
ADMIN_PASSWORD=changeme

# Hostname this DNS server identifies itself as (unique per instance)
# e.g. dns-tower or dns-prod
DNS_SERVER_DOMAIN=dns-tower
