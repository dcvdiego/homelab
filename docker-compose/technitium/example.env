# IMPORTANT: HOST_IP must be set to the LAN IP of the host this is deployed on.
# This binds DNS port 53 only to the LAN interface, which:
#   - avoids conflicts with systemd-resolved (127.0.0.53:53) on docker-tower
#   - prevents DNS from being reachable on Docker internal bridge networks
#
# docker-prod  (ep3): HOST_IP=192.168.1.224
# docker-tower (ep2): HOST_IP=192.168.1.248
HOST_IP=192.168.1.x

# Technitium web UI admin password
ADMIN_PASSWORD=changeme

# Hostname this DNS server identifies itself as (used in SOA records)
# Use a unique name per instance so you can tell them apart in logs
# e.g. dns-prod or dns-tower
DNS_SERVER_DOMAIN=dns-prod
